# ==============================================
# AIO HEALTHCARE SYSTEM - CONFIGURATION
# ==============================================

# --- AI & MODEL KEYS ---
# Required for Chatbot and Vision Analysis
GOOGLE_API_KEY=your_gemini_api_key_here

# --- PAYMENTS (RAZORPAY) ---
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# --- DATABASE SETTINGS ---
# Default is SQLite (local). For Production, use PostgreSQL URL.
DATABASE_URL=sqlite:///./healthcare.db
# Example Prod: postgresql://user:pass@127.0.0.1/dbname

# --- SECURITY ---
# Required secret key for JWT token signing.
SECRET_KEY=generate_a_secure_random_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Optional one-time admin bootstrap. Leave unset unless intentionally seeding an admin.
# DEFAULT_ADMIN_USERNAME=ops-admin
# DEFAULT_ADMIN_PASSWORD=replace_with_a_strong_unique_password
# DEFAULT_ADMIN_EMAIL=ops-admin@example.com

# --- BACKEND SETTINGS ---
# URL where the backend API is running (for Frontend connection)
BACKEND_URL=http://127.0.0.1:8000
# Comma-separated backend hostnames accepted by TrustedHostMiddleware.
ALLOWED_HOSTS=127.0.0.1
# Comma-separated browser origins allowed to call the API.
CORS_ORIGINS=http://127.0.0.1:3000
# Per-user/IP API rate limit for non-public endpoints.
RATE_LIMIT_REQUESTS_PER_MINUTE=60
# Set to 'true' to enable detailed error logs in responses (Dev only)
TESTING=false

# --- DEPLOYMENT ---
# Port configuration
PORT=8000

# --- BACKUP / RESTORE READINESS ---
# Metadata only: the app does not execute backups. Configure these from the deployment operator's runbook.
BACKUP_ENABLED=false
# BACKUP_PROVIDER=managed-postgres
# BACKUP_STORAGE_REGION=ap-south-1
# BACKUP_RETENTION_DAYS=35
# BACKUP_LAST_SUCCESS_AT=2026-05-27T10:00:00+00:00
# BACKUP_RESTORE_TESTED_AT=2026-05-01T10:00:00+00:00
# BACKUP_ENCRYPTION_ENABLED=true
# BACKUP_OWNER_CONTACT=ops-on-call
# BACKUP_RUNBOOK_URL=https://docs.example.com/runbooks/backup-restore

# --- INCIDENT RESPONSE / ALERT READINESS ---
# Metadata only: the app does not send alerts. Configure these from the deployment operator's incident runbook.
INCIDENT_RESPONSE_ENABLED=false
# INCIDENT_RESPONSE_OWNER_CONTACT=ops-on-call
# INCIDENT_RESPONSE_CHANNEL=security-alerts
# INCIDENT_RESPONSE_RUNBOOK_URL=https://docs.example.com/runbooks/incidents
# INCIDENT_RESPONSE_SEVERITY_MATRIX_URL=https://docs.example.com/runbooks/severity
# INCIDENT_BREACH_NOTIFICATION_CONTACT=privacy-or-security-contact
# ALERT_ERROR_RATE_THRESHOLD_PERCENT=5
# ALERT_AI_FAILURE_RATE_THRESHOLD_PERCENT=10
# ALERT_PIPELINE_STALENESS_MINUTES=30
# ALERT_SECURITY_EVENT_THRESHOLD=3

# --- RETENTION POLICY READINESS ---
# Metadata only: the app does not delete or archive records from these settings.
RETENTION_POLICY_ENABLED=false
# RETENTION_OWNER_CONTACT=privacy-owner
# RETENTION_RUNBOOK_URL=https://docs.example.com/runbooks/retention
# LEGAL_HOLD_PROCESS_URL=https://docs.example.com/runbooks/legal-hold
# PATIENT_RECORD_RETENTION_YEARS=8
# CHAT_LOG_RETENTION_DAYS=365
# AUDIT_LOG_RETENTION_DAYS=2555
# INTEROPERABILITY_EXPORT_RETENTION_DAYS=365
# VECTOR_STORE_RETENTION_DAYS=365
# LAKEHOUSE_RETENTION_DAYS=730

# --- SECURITY ASSURANCE READINESS ---
# Metadata only: the app does not run scans or generate SBOMs from these settings.
SECURITY_ASSURANCE_ENABLED=false
# SECURITY_OWNER_CONTACT=security-owner
# SECURITY_RUNBOOK_URL=https://docs.example.com/runbooks/security-assurance
# SECRET_SCAN_LAST_RUN_AT=2026-05-27T10:00:00+00:00
# DEPENDENCY_SCAN_LAST_RUN_AT=2026-05-27T10:00:00+00:00
# SBOM_GENERATED_AT=2026-05-27T10:00:00+00:00
# VULNERABILITY_SCAN_LAST_RUN_AT=2026-05-27T10:00:00+00:00
# PEN_TEST_REPORT_URL=https://docs.example.com/security/pentest
# SECURITY_FINDINGS_OPEN_CRITICAL=0
# SECURITY_FINDINGS_OPEN_HIGH=0

# --- LOCAL AI (OLLAMA) ---
# Enables zero-cost, HIPAA-friendly local inference. Data never leaves your machine.
# Install: https://ollama.com | Pull a model: ollama pull llama3.2
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120

# --- GEMINI MODEL SELECTION ---
# Which Gemini model to use (default: gemini-1.5-flash for free tier reliability)
GEMINI_MODEL=gemini-1.5-flash

# --- CLOUD AI FALLBACK (Optional) ---
# These are ONLY used if explicitly requested via x-ai-provider header
# or if Ollama + Gemini are both unavailable.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- INDIA ABDM CONNECTOR (Optional) ---
# Keep disabled until the deployment has ABDM sandbox/production onboarding values.
ABDM_ENABLED=false
# Set to true to bypass configuration requirements and return mock success responses for sales demos/funding pitches
# ABDM_DEMO_MODE=true
ABDM_ENVIRONMENT=sandbox
# ABDM_BASE_URL=https://dev.abdm.gov.in
ABDM_CONSENT_REQUEST_PATH=/v3/consent/request/init
ABDM_CM_ID=sbx
# ABDM_HIU_ID=your_hiu_id
# ABDM_HIP_ID=your_hip_id
# ABDM_CLIENT_ID=your_abdm_client_id
# ABDM_CLIENT_SECRET=your_abdm_client_secret
# ABDM_ACCESS_TOKEN=short_lived_abdm_access_token
ABDM_REQUESTER_NAME=NexusHealth
ABDM_REQUESTER_IDENTIFIER_TYPE=REGNO
ABDM_REQUESTER_IDENTIFIER_SYSTEM=https://facility.abdm.gov.in
# ABDM_REQUESTER_IDENTIFIER_VALUE=your_hfr_or_facility_identifier
ABDM_TIMEOUT_SECONDS=20

# --- DICOMWEB / PACS CONNECTOR (Optional) ---
# Metadata-link readiness only; no image storage or PACS calls are made unless a future connector enables them.
DICOMWEB_ENABLED=false
# DICOMWEB_BASE_URL=https://pacs.example.com/dicomweb
# DICOMWEB_AE_TITLE=YOUR_AE_TITLE
# DICOMWEB_BEARER_TOKEN=short_lived_pacs_token

# --- SMART ON FHIR / EHR LAUNCH (Optional) ---
# Readiness and authorization URL generation only; no token exchange is performed by default.
SMART_FHIR_ENABLED=false
# SMART_FHIR_BASE_URL=https://ehr.example.com/fhir
# SMART_AUTHORIZATION_ENDPOINT=https://ehr.example.com/auth
# SMART_TOKEN_ENDPOINT=https://ehr.example.com/token
# SMART_CLIENT_ID=registered_smart_client_id
# SMART_CLIENT_SECRET=registered_smart_client_secret
# SMART_REDIRECT_URI=https://app.example.com/smart/callback
SMART_SCOPES=launch/patient patient/*.read openid fhirUser
