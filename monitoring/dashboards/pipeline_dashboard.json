{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "DAG Run Duration",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "airflow_dag_run_duration_seconds{dag_id=\"healthcare_data_pipeline\"}",
          "legendFormat": "{{dag_id}} - Run Duration",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "title": "Task Success/Failure Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(airflow_task_status{status=\"success\"}[5m]))",
          "legendFormat": "Successes",
          "refId": "A"
        },
        {
          "expr": "sum(rate(airflow_task_status{status=\"failed\"}[5m]))",
          "legendFormat": "Failures",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "title": "Data Quality Scores by Dataset",
      "type": "gauge",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "dataset_quality_score",
          "legendFormat": "{{dataset_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.90 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "id": 4,
      "title": "Dead Letter Queue Size",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "dlq_records_count",
          "legendFormat": "DLQ Size",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "id": 5,
      "title": "ETL Records Processed",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(etl_records_processed_total[5m]))",
          "legendFormat": "Records/sec",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "id": 6,
      "title": "Cache Hit/Miss Ratio",
      "type": "piechart",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(cache_hits_total[15m]))",
          "legendFormat": "Cache Hits",
          "refId": "A"
        },
        {
          "expr": "sum(rate(cache_misses_total[15m]))",
          "legendFormat": "Cache Misses",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "id": 7,
      "title": "Model Prediction Latency",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(prediction_latency_seconds_bucket[5m])) by (le, model_name))",
          "legendFormat": "{{model_name}} (p95)",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 22
      },
      "id": 8,
      "title": "Feature Drift PSI",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "feature_drift_psi",
          "legendFormat": "{{model_name}} - {{feature_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineStyle": { "fill": "solid" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.1 },
              { "color": "red", "value": 0.25 }
            ]
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 22
      },
      "id": 9,
      "title": "Pipeline Data Freshness SLA",
      "type": "table",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "dataset_staleness_hours",
          "legendFormat": "{{dataset_id}} staleness",
          "refId": "A"
        },
        {
          "expr": "dataset_sla_hours",
          "legendFormat": "{{dataset_id}} SLA",
          "refId": "B"
        }
      ]
    }
  ],
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["pipeline", "airflow", "mlops"],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "timezone": "utc",
  "title": "AI Healthcare Data Pipeline & MLOps Dashboard",
  "variables": {
    "list": [
      {
        "current": {
          "selected": true,
          "value": "production"
        },
        "hide": 0,
        "name": "environment",
        "options": [
          { "selected": true, "text": "Production", "value": "production" },
          { "selected": false, "text": "Staging", "value": "staging" },
          { "selected": false, "text": "Development", "value": "development" }
        ],
        "query": "production,staging,development",
        "type": "custom"
      }
    ]
  }
}
