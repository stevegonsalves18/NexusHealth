      "metadata": {},
      "source": [
        "### 1. Clone the Codebase & Install Dependencies"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Clone the repository\n",
        "!git clone https://github.com/stevegonsalves18/NexusHealth.git\n",
        "%cd NexusHealth\n",
        "\n",
        "# Install PySpark, Delta Lake, XGBoost, and database drivers\n",
        "!pip install pyspark delta-spark xgboost scikit-learn pandas sqlalchemy psycopg2-binary requests"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### 2. Configure Credentials & Run Pipeline\n",
        "Configure your database connection (Neon/Supabase PostgreSQL) and Hugging Face deployment credentials below, then run the cell to execute the Spark ETL and model training."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        import os\n",
        "\n",
        "# 1. Connection string for your persistent database (Neon/Supabase PostgreSQL)\n",
        "os.environ[\"DATABASE_URL\"] = \"your_postgresql_database_url_here\"\n",
        "\n",
        "# 2. Credentials to trigger zero-downtime model reload on Hugging Face (Optional)\n",
        "os.environ[\"BACKEND_URL\"] = \"https://stevegonsalves18-NexusHealth.hf.space\"\n",
        "os.environ[\"ADMIN_JWT_TOKEN\"] = \"your_admin_jwt_token_here\"\n",
        "\n",
        "# Execute the runner\n",
        "!python scripts/runners/run_spark_etl.py"
      ]
